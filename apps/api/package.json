{
  "name": "@entrostat-otp/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "npm run build -w @entrostat-otp/shared",
    "build": "tsc -p tsconfig.json",
