{
  "name": "@entrostat-otp/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "npm run build -w @entrostat-otp/shared && npm run prisma:generate",
    "build": "tsc -p tsconfig.json",
    "predev": "npm run build -w @entrostat-otp/shared && npm run prisma:generate",
    "dev": "node --env-file=../../.env ../../node_modules/tsx/dist/cli.mjs watch src/server.ts",
    "prisma:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "start": "node dist/server.js",
    "test": "vitest run --dir .",
    "pretypecheck": "npm run prisma:generate",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@entrostat-otp/shared": "file:../../packages/shared",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "express": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.20.6"
  }
}
